# OpenAI API
# Copy this file to .env and set your own key.
OPENAI_API_KEY=

# Camera/source behavior
CAMERA_OVERLAP_SECONDS=2.0

# OpenAI models
AI_MODEL=gpt-5.5
IMAGE_MODEL=gpt-image-1.5

# Render settings
RENDER_PRESET=fast
RENDER_CRF=22
AUDIO_BITRATE=128k
ENABLE_STABILIZATION=false
STABILIZATION_FILTER=deshake=rx=16:ry=16:edge=mirror:blocksize=16:contrast=100:search=less

# FFmpeg filters
VIDEO_ENHANCE_FILTER=hqdn3d=1.0:1.0:3:3,eq=contrast=1.06:brightness=0.01:saturation=1.12:gamma=0.99,unsharp=5:5:0.45:3:3:0.20
AUDIO_ENHANCE_FILTER=highpass=f=100,lowpass=f=8500,afftdn=nf=-22,acompressor=threshold=-18dB:ratio=2.6:attack=12:release=180,volume=1.6,alimiter=limit=0.95

# Creator/channel context used by AI for titles, descriptions, tags, and thumbnails.
# You can either fill the structured fields below or set CREATOR_CONTEXT directly.
CREATOR_NAME=
CREATOR_AGE=
CREATOR_INTERESTS=
PREVIOUS_MOTORCYCLE=
PREVIOUS_MOTORCYCLE_CONTEXT=
CURRENT_MOTORCYCLE=
CURRENT_MOTORCYCLE_CONTEXT=
CONTENT_CONTEXT_GUIDANCE=

# Example of a direct free-form context override:
# CREATOR_CONTEXT=The creator rides a Yamaha FZ25 and makes Brazilian Portuguese motovlogs about commuting and motorcycle travel.
